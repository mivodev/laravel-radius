{
    "name": "mivodev/laravel-radius",
    "description": "Laravel Wrapper for Mivo Radius UDP Client with Hybrid Connection Manager.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/mivodev/laravel-radius",
    "support": {
        "issues": "https://github.com/mivodev/laravel-radius/issues",
        "source": "https://github.com/mivodev/laravel-radius"
    },
    "keywords": [
        "laravel",
        "radius",
        "mivo",
        "facade",
        "udp"
    ],
    "authors": [
        {
            "name": "Mivo Enterprise",
            "email": "mivo@dev.dyzulk.com",
            "homepage": "https://github.com/mivodev",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^13.0",
        "mivodev/radius": "*"
    },
    "autoload": {
        "psr-4": {
            "Mivo\\LaravelRadius\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mivo\\LaravelRadius\\RadiusServiceProvider"
            ],
            "aliases": {
                "Radius": "Mivo\\LaravelRadius\\Facades\\Radius"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
