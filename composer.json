{
    "name": "mivodev/laravel-radius",
    "description": "Laravel Wrapper for Mivo Enterprise Core RADIUS Integration",
    "type": "library",
    "require": {
        "php": "^8.2 | ^8.3",
        "mivodev/radius": "*",
        "illuminate/support": "^10.0 | ^11.0 | ^12.0 | ^13.0"
    },
    "autoload": {
        "psr-4": {
            "Mivo\\LaravelRadius\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mivo\\LaravelRadius\\RadiusServiceProvider"
            ]
        }
    }
}
